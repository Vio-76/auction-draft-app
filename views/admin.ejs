<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="<%= fontUrl %>">
  <link rel="stylesheet" href="/static/css/theme.css">
  <link rel="stylesheet" href="/static/css/admin.css">
  <title>Auction Admin</title>
</head>
<body data-theme="<%= theme %>">
  <div class="admin-shell">
    <header class="admin-head">
      <div>
        <div class="admin-eyebrow">Auction</div>
        <h1 class="admin-title">Admin Console</h1>
      </div>
      <div class="admin-head-right">
        <span class="conn" id="conn">connecting…</span>
        <a class="btn btn-ghost" href="/board" target="_blank" rel="noopener">Board ↗</a>
        <form method="post" action="/admin/logout" style="display:inline"><button class="btn btn-ghost" type="submit">Log out</button></form>
      </div>
    </header>

    <!-- Live status + auction control -->
    <section class="card">
      <h2>Auction control</h2>
      <div class="status-line">
        <div class="status-grid" id="status-bar"></div>
        <button class="btn btn-accent sell-btn" id="sold-btn" onclick="adminAction('sold')">Sell player</button>
      </div>
      <div class="btn-row">
        <button class="btn" onclick="adminAction('start', {}, 'Start the auction? This clears in-flight bidding and starts from the first captain.')">Start auction</button>
        <button class="btn" onclick="adminAction('skip')">Skip Turn</button>
        <button class="btn btn-danger" onclick="adminAction('empty-teams', {}, 'Empty all teams? Every drafted player returns to the pool (captains stay). The turn order is not changed — use Start auction to begin again.')">Empty teams</button>
      </div>
    </section>

    <div class="cols">
      <!-- Settings -->
      <section class="card">
        <h2>Settings</h2>
        <div class="form-grid">
          <label>Turn order
            <select id="set-turnOrder"><option value="WATERFALL">WATERFALL</option><option value="SNAKE">SNAKE</option></select>
          </label>
          <label>Snake direction
            <select id="set-turnDirection"><option value="DOWN">DOWN</option><option value="UP">UP</option></select>
          </label>
          <label>Sell mode
            <select id="set-sellMode"><option value="MANUAL">MANUAL</option><option value="AUTO">AUTO</option></select>
          </label>
          <label>Auto-sell window (s) <input type="number" id="set-autoWindow" min="0" step="1"></label>
          <label>Small blind <input type="number" id="set-smallBlind" min="0" step="1"></label>
          <label>Team budget <input type="number" id="set-teamBudget" min="0" step="1"></label>
          <label>Opening timeout (s) <input type="number" id="set-openingTimeout" min="0" step="1"></label>
          <label>Sold cooldown (s) <input type="number" id="set-soldCooldown" min="0" step="1"></label>
          <label>Show bids on board
            <select id="set-showBidOnBoard"><option value="true">Show (public)</option><option value="false">Hide (captains only)</option></select>
          </label>
          <label>Team slots <input type="number" id="set-teamSlots" min="1" step="1"></label>
          <label>Theme
            <select id="set-theme">
              <option>draftroom</option><option>auctionhouse</option><option>terminal</option>
              <option>broadcast</option><option>brutalist</option><option>casino</option>
            </select>
          </label>
          <button class="btn btn-accent set-save" onclick="saveSettings()">Save settings</button>
        </div>
        <div class="btn-row hint-right">
          <span class="hint">Theme change applies on each viewer's next page refresh.</span>
        </div>
      </section>

      <!-- Status -->
      <section class="card">
        <h2>Status</h2>
        <div class="btn-col">
          <button class="btn" onclick="adminAction('close-bidding')">Pause (close)</button>
          <button class="btn" onclick="adminAction('open-opening')">Set Opening Bid Phase</button>
          <button class="btn" onclick="adminAction('open-bidding')">Set Bidding Phase</button>
          <button class="btn" onclick="adminAction('status', {status:'FINISHED'})">Set Finished</button>
        </div>
      </section>
    </div>

    <!-- Captains -->
    <section class="card">
      <div class="card-head">
        <h2>Captains</h2>
        <button class="btn" onclick="addCaptain()">+ Add captain</button>
      </div>

      <details class="import-box">
        <summary>Bulk import (paste a captain list)</summary>
        <p class="hint">One captain per line, in the table's column order: <code>Name &lt;tab/comma&gt; Role, Discord, Code, Price</code>. Only the name is required.</p>
        <textarea id="captain-import-text" rows="6" placeholder="Monarch	Top	cap_monarch	mon	5&#10;Tomi, Jungle, tomi_dc, tom, 4"></textarea>
        <div class="btn-row">
          <label class="inline">Mode
            <select id="captain-import-mode"><option value="replace">Replace all captains</option><option value="append">Append</option></select>
          </label>
          <button class="btn btn-accent" onclick="importCaptains()">Import</button>
        </div>
      </details>

      <div class="table-wrap"><table class="tbl" id="captains-tbl"></table></div>
    </section>

    <!-- Players + import -->
    <section class="card">
      <div class="card-head">
        <h2>Players</h2>
        <div class="btn-row">
          <button class="btn" onclick="addPlayer()">+ Add player</button>
          <button class="btn btn-danger" onclick="adminAction('pool/clear', {}, 'Remove every OPEN (undrafted) player from the pool?')">Clear pool</button>
        </div>
      </div>

      <details class="import-box">
        <summary>Bulk import (paste a player list)</summary>
        <p class="hint">One player per line, in the table's column order: <code>Name &lt;tab/comma&gt; Role, Discord</code>. Role and Discord are optional.</p>
        <textarea id="import-text" rows="8" placeholder="Faker	Mid	faker_gg&#10;Caps,Mid,caps_dc&#10;Zeus	Top"></textarea>
        <div class="btn-row">
          <label class="inline">Mode
            <select id="import-mode"><option value="replace">Replace open pool</option><option value="append">Append</option></select>
          </label>
          <button class="btn btn-accent" onclick="importPlayers()">Import</button>
        </div>
      </details>

      <div class="filter-row">
        <label class="inline">Filter
          <select id="player-filter" onchange="renderPlayers()"><option value="all">All</option><option value="open">Open</option><option value="sold">Drafted</option></select>
        </label>
        <span class="hint" id="player-count"></span>
      </div>
      <div class="table-wrap"><table class="tbl" id="players-tbl"></table></div>
    </section>

    <!-- Team export string for discord -->
    <section class="card">
      <div class="card-head">
        <h2>Team export string for discord</h2>
        <button class="btn" onclick="copyTeamString()">Copy team string</button>
      </div>

      <p class="hint">Team string (captain first, then drafted players; Team N order matches the board):</p>
      <textarea id="team-string" rows="4" readonly></textarea>
    </section>
  </div>

  <script>window.ROLE_LABELS = <%- JSON.stringify(roleLabels) %>;</script>
  <script src="/static/js/shared.js"></script>
  <script src="/static/js/admin.js"></script>
</body>
</html>
